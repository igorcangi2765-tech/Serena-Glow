# --- Frontend (Vite) ---
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Set this to the production URL if backend is on a different domain/subdomain
# If serving from the same Node process, leave empty or use /api
# VITE_API_URL=https://your-domain.com/api

# --- Backend (Node.js) ---
# Use the Service Role Key for backend operations if needed (bypass RLS)
# Otherwise, Anon Key is used as fallback in server/index.ts
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Server Port (Hostinger's Node selector often sets this via process.env.PORT)
PORT=3001

# Environment
NODE_ENV=production
